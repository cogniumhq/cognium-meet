{
  "name": "cognium-meet",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel -r dev",
    "dev:api": "pnpm --filter @cognium/meet-api dev",
    "dev:extension": "pnpm --filter @cognium/meet-extension dev",
    "test": "pnpm --filter @cognium/meet-shared test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "overrides": {
      "fs-extra": "^11.3.0"
    }
  }
}
