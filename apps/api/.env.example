OPENAI_API_KEY=sk-your-key-here
PORT=3847
API_TOKEN=dev-token-change-me
STORAGE_DIR=../../storage
DELETE_AUDIO_AFTER_TRANSCRIPTION=true
MAX_UPLOAD_BYTES=157286400
# Default when the extension does not send a model (extension Settings overrides per upload)
# TRANSCRIPTION_MODEL=gpt-4o-transcribe-diarize
# TRANSCRIPTION_MODEL=whisper-1
# Auto-generate meeting notes after transcription (summary, action items, decisions, open questions)
MEETING_NOTES_ENABLED=true
MEETING_NOTES_MODEL=gpt-4o-mini
MEETING_ASK_ENABLED=true
# Provider for notes + Ask models: openai | ollama
MEETING_LLM_PROVIDER=openai
# Used when MEETING_LLM_PROVIDER=ollama
# Ollama OpenAI-compatible base ("/v1" is appended automatically if omitted)
OLLAMA_URL=http://localhost:11434
MEETING_OLLAMA_MODEL=qwen2.5:7b
