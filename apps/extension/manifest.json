{
  "manifest_version": 3,
  "name": "Cognium Meet",
  "description": "Record browser tab audio and transcribe to text files",
  "version": "0.5.0",
  "permissions": ["tabCapture", "offscreen", "storage", "activeTab", "tabs"],
  "host_permissions": ["http://localhost:3847/*", "http://127.0.0.1:3847/*"],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Cognium Meet"
  },
  "options_page": "src/options/options.html",
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/offscreen/offscreen.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
